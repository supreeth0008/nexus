# I configure Nexus via environment variables – all NEXUS_ prefix
# Copy to .env and adjust – never commit secrets

# Project
NEXUS_PROJECT_NAME=nexus-prod
NEXUS_PROJECT_ENVIRONMENT=prod

# Autonomy: 0=observe,1=recommend,2=auto-fix low risk,3=policy gate,4=full
NEXUS_AUTONOMY_LEVEL=2

# Database – PostgreSQL
NEXUS_DATABASE_DSN=postgres://nexus:REDACTED@localhost:5432/nexus?sslmode=require

# Engine
NEXUS_ENGINE_CYCLE_INTERVAL=5m
NEXUS_ENGINE_HTTP_PORT=8080

# API Security – I require one of these in production
NEXUS_API_KEY=nx_admin_CHANGE_ME_IN_PRODUCTION
# NEXUS_API_KEYS=nx_admin_xxx,nx_operator_yyy
NEXUS_ENV=prod

# Audit signing – I HMAC-SHA256 sign every ledger entry
NEXUS_AUDIT_HMAC_KEY=change-me-32-byte-min

# GitOps – I create PRs via GitHub App
# NEXUS_GITHUB_TOKEN=ghp_xxx
# NEXUS_GITHUB_REPO=supreeth0008/nexus-infra

# TLS – I terminate TLS at the API
# NEXUS_TLS_CERT=/etc/nexus/tls.crt
# NEXUS_TLS_KEY=/etc/nexus/tls.key

# OTel – I export traces
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
